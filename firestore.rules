rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return isSignedIn() &&
          exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return hasProfile() && me().role == 'admin';
    }

    function isParent() {
      return hasProfile() && me().role == 'parent';
    }

    function isTeacher() {
      return hasProfile() && me().role == 'teacher';
    }

    function isStudent() {
      return hasProfile() && me().role == 'student';
    }

    function isGate() {
      return hasProfile() && me().role == 'gate';
    }

    function isOwnUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isParentOfStudent(studentUid) {
      return isParent() &&
          me().children is list &&
          me().children.hasAny([studentUid]);
    }

    function isTeacherForClass(classId) {
      return isTeacher() && me().classId == classId;
    }

    function onlyOwnInboxFieldsChanged() {
      // twoFactorVerifiedUntil is intentionally NOT in this list: it is the
      // trusted-session marker enforced by rules elsewhere, and must only be
      // written by the authVerifySecondFactor Cloud Function (Admin SDK
      // bypasses rules). Allowing client writes here would let a compromised
      // client extend its 2FA window arbitrarily.
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'unreadCount',
        'inboxLastOpenedAt',
        'requestsLastOpenedAt',
        'profilePictureUrl',
        'photoUrl',
        'authEmail',
        'updatedAt',
        'fcmToken',
        'passwordChanged',
      ]);
    }

    function validLeaveRequestCreate() {
      return isStudent() &&
          request.resource.data.keys().hasAll([
            'studentUid',
            'studentUsername',
            'studentName',
            'classId',
            'dateText',
            'timeText',
            'message',
            'status',
            'requestedAt',
            'reviewedAt',
            'reviewedByUid',
            'reviewedByName',
          ]) &&
          request.resource.data.studentUid == request.auth.uid &&
          request.resource.data.classId == me().classId &&
          request.resource.data.status == 'pending' &&
          request.resource.data.requestedAt is timestamp &&
          request.resource.data.reviewedAt == null &&
          request.resource.data.reviewedByUid == null &&
          request.resource.data.reviewedByName == null;
    }

    function validAdminGlobalMessage() {
      return isAdmin() &&
          request.resource.data.keys().hasAll([
            'message',
            'targetRole',
            'status',
            'requestedAt',
            'reviewedAt',
            'reviewedByUid',
            'reviewedByName',
            'source',
          ]) &&
          request.resource.data.source == 'secretariat' &&
          request.resource.data.status == 'approved' &&
          request.resource.data.reviewedByUid == request.auth.uid &&
          request.resource.data.requestedAt is timestamp &&
          request.resource.data.reviewedAt is timestamp;
    }

    function validLeaveReviewUpdate() {
      return resource.data.status == 'pending' &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'status',
            'reviewedAt',
            'reviewedByUid',
            'reviewedByName',
          ]) &&
          ['approved', 'rejected'].hasAny([request.resource.data.status]) &&
          request.resource.data.reviewedByUid == request.auth.uid &&
          request.resource.data.reviewedAt is timestamp;
    }

    function canReadLeaveRequest() {
      return isAdmin() ||
          (isStudent() && resource.data.studentUid == request.auth.uid) ||
          isParentOfStudent(resource.data.studentUid) ||
          isTeacherForClass(resource.data.classId) ||
          (isParent() && resource.data.targetUid == request.auth.uid);
    }

    function canReviewLeaveRequest() {
      return validLeaveReviewUpdate() &&
          (isAdmin() ||
              isParentOfStudent(resource.data.studentUid) ||
              isTeacherForClass(resource.data.classId));
    }

    function canReadAccessEvent() {
      return isAdmin() ||
          isGate() ||
          (isStudent() && resource.data.userId == request.auth.uid) ||
          isParentOfStudent(resource.data.userId) ||
          isTeacherForClass(resource.data.classId);
    }

    function validSecretariatMessageCreate() {
      return isAdmin() &&
          request.resource.data.keys().hasAll([
            'recipientRole',
            'recipientUid',
            'studentUid',
            'studentName',
            'classId',
            'message',
            'title',
            'createdAt',
            'senderUid',
            'senderName',
            'broadcastId',
            'messageType',
            'source',
          ]) &&
          ['student', 'parent', 'teacher'].hasAny([
            request.resource.data.recipientRole,
          ]) &&
          request.resource.data.recipientUid == '' &&
          request.resource.data.studentUid == '' &&
          request.resource.data.source == 'secretariat' &&
          request.resource.data.messageType == 'secretariatGlobal' &&
          request.resource.data.senderUid == request.auth.uid &&
          request.resource.data.createdAt is timestamp;
    }

    // Teachers may broadcast to their own class OR to the whole school. The
    // post is locked to source='teacher' so it stays in a separate lane from
    // secretariat broadcasts, and audienceClassIds must be exactly one entry —
    // either the teacher's own classId or the school-wide sentinel.
    function validTeacherSecretariatMessageCreate() {
      return isTeacher() &&
          request.resource.data.keys().hasAll([
            'recipientRole',
            'recipientUid',
            'studentUid',
            'studentName',
            'classId',
            'message',
            'title',
            'createdAt',
            'senderUid',
            'senderName',
            'broadcastId',
            'messageType',
            'source',
            'audienceClassIds',
          ]) &&
          request.resource.data.recipientRole == 'student' &&
          request.resource.data.recipientUid == '' &&
          request.resource.data.studentUid == '' &&
          request.resource.data.source == 'teacher' &&
          request.resource.data.messageType == 'secretariatGlobal' &&
          request.resource.data.senderUid == request.auth.uid &&
          request.resource.data.createdAt is timestamp &&
          request.resource.data.audienceClassIds is list &&
          request.resource.data.audienceClassIds.size() == 1 &&
          (request.resource.data.audienceClassIds[0] == me().classId ||
              request.resource.data.audienceClassIds[0] == '__ALL__');
    }

    // Teachers can only flip the status of their own post between active and
    // archived — no editing of title/body/audience after the fact.
    function validTeacherSecretariatMessageUpdate() {
      return isTeacher() &&
          resource.data.source == 'teacher' &&
          resource.data.senderUid == request.auth.uid &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'status',
          ]) &&
          ['active', 'archived'].hasAny([request.resource.data.status]);
    }

    // ── secretariatMessages read visibility ─────────────────────────────
    // Each helper assumes the caller has already been checked to hold the
    // matching role. Helpers are split per role + per recipientRole so the
    // logic stays auditable: there is exactly one place to change when
    // visibility for "X reads Y-targeted message" must be tightened.

    function secretariatStudentReadsStudentMsg() {
      // Student reads a student-targeted message when it is addressed to
      // them directly OR is a school-wide student broadcast.
      return resource.data.recipientUid == request.auth.uid ||
          resource.data.recipientUid == '';
    }

    function secretariatParentReadsParentMsg() {
      // Parent reads a parent-targeted message when it is a school-wide
      // parent broadcast OR is tied to one of their children.
      return resource.data.studentUid == '' ||
          isParentOfStudent(resource.data.studentUid);
    }

    function secretariatParentReadsStudentMsg() {
      // Parent also sees student-targeted announcements that touch their
      // children: school-wide student broadcasts, or messages tied to a
      // specific student/parent uid that resolves to one of their children.
      return resource.data.recipientUid == '' ||
          isParentOfStudent(resource.data.recipientUid) ||
          isParentOfStudent(resource.data.studentUid);
    }

    function secretariatTeacherReadsTeacherMsg() {
      // Teacher reads a teacher-targeted message when it is addressed to
      // them directly OR is a school-wide teacher broadcast.
      return resource.data.recipientUid == request.auth.uid ||
          resource.data.recipientUid == '';
    }

    function secretariatTeacherReadsStudentMsg() {
      // Teachers see school-wide student broadcasts so they get the same
      // announcements as their students. Direct/per-class targeting is not
      // implemented here intentionally.
      return resource.data.recipientUid == '';
    }

    function canReadSecretariatMessage() {
      return isAdmin() ||
          (isStudent() && resource.data.recipientRole == 'student' &&
              secretariatStudentReadsStudentMsg()) ||
          (isParent() && resource.data.recipientRole == 'parent' &&
              secretariatParentReadsParentMsg()) ||
          (isParent() && resource.data.recipientRole == 'student' &&
              secretariatParentReadsStudentMsg()) ||
          (isTeacher() && resource.data.recipientRole == 'teacher' &&
              secretariatTeacherReadsTeacherMsg()) ||
          (isTeacher() && resource.data.recipientRole == 'student' &&
              secretariatTeacherReadsStudentMsg());
    }

    match /users/{userId} {
      // The parent user doc holds sensitive fields (personalEmail, fcmToken,
      // twoFactorVerifiedUntil, etc.) and must NOT be readable by arbitrary
      // signed-in users. Other authenticated users should look up directory
      // data via the publicProfile subcollection below.
      //
      // Teachers additionally need to list students in their own class for the
      // class-roster screen. The query filters by role=='student' and
      // classId==<teacher's classId>, so the rule mirrors those constraints —
      // teachers cannot read users outside their class or non-student users.
      allow read: if isOwnUser(userId) || isAdmin() ||
          (isTeacher() &&
              resource.data.role == 'student' &&
              resource.data.classId == me().classId);
      allow create: if isAdmin();
      allow update: if isAdmin() ||
          (isOwnUser(userId) && onlyOwnInboxFieldsChanged());
      allow delete: if isAdmin();

      match /bookmarks/{itemId} {
        allow read, write: if isOwnUser(userId);
      }

      // Non-sensitive profile mirror maintained by the onUserDocWrite trigger
      // (Admin SDK bypasses these rules). Reads are open to any signed-in
      // user so future client code can list/lookup directory data without the
      // parent users doc exposing personalEmail/fcmToken.
      match /publicProfile/{docId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    match /app_settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /classes/{classId} {
      // Secretariat UI reads class lists directly from Firestore.
      // Keep writes admin-only, but allow reads for authenticated users.
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /vacancies/{vacancyId} {
      // Vacancies are managed from the secretariat/admin area.
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /leaveRequests/{requestId} {
      allow read: if canReadLeaveRequest();
      allow create: if validLeaveRequestCreate() || validAdminGlobalMessage();
      allow update: if canReviewLeaveRequest();
      allow delete: if isAdmin();
    }

    match /secretariatMessages/{messageId} {
      allow read: if canReadSecretariatMessage();
      allow create: if validSecretariatMessageCreate() ||
          validTeacherSecretariatMessageCreate();
      allow update: if isAdmin() || validTeacherSecretariatMessageUpdate();
      allow delete: if isAdmin() ||
          (isTeacher() &&
              resource.data.source == 'teacher' &&
              resource.data.senderUid == request.auth.uid);
    }

    match /secretariatActivity/{activityId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /accessEvents/{eventId} {
      allow read: if canReadAccessEvent();
      // Writes flow exclusively through the redeemQrToken Cloud Function
      // (Admin SDK bypasses these rules). Direct client writes — even by gate
      // accounts — are rejected to prevent forged entry/exit events.
      allow create, update, delete: if false;
    }

    match /qrTokens/{tokenId} {
      allow read: if isAdmin() ||
          (isStudent() && resource.data.userId == request.auth.uid);
      // Writes flow exclusively through the generateQrToken Cloud Function
      // (Admin SDK bypasses these rules). Direct client writes are rejected so
      // a student cannot forge a qrToken with an arbitrary expiresAt.
      allow create, update: if false;
      allow delete: if isAdmin() ||
          (isStudent() && resource.data.userId == request.auth.uid);
    }

    match /volunteerOpportunities/{opportunityId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() ||
          (isTeacher() &&
           request.resource.data.createdByRole == 'teacher' &&
           request.resource.data.createdBy == request.auth.uid &&
           request.resource.data.createdAt is timestamp);
      allow update: if isAdmin() ||
          (isTeacher() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin() ||
          (isTeacher() && resource.data.createdBy == request.auth.uid);
    }

    match /volunteerSignups/{signupId} {
      allow read: if isAdmin() ||
          (isStudent() && resource.data.studentUid == request.auth.uid) ||
          isTeacherForClass(resource.data.classId) ||
          isParentOfStudent(resource.data.studentUid);
      allow create: if isStudent() &&
          request.resource.data.studentUid == request.auth.uid &&
          request.resource.data.status == 'signed_up' &&
          request.resource.data.signedUpAt is timestamp;
      allow update: if isAdmin() ||
          (isStudent() && resource.data.studentUid == request.auth.uid &&
           request.resource.data.status == 'cancelled') ||
          (isTeacher() && isTeacherForClass(resource.data.classId));
      allow delete: if isAdmin();
    }

    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /timetables/{classId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
